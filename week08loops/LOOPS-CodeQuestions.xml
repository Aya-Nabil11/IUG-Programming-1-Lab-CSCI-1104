  <question type="essay">
    <name>
      <text>String palindrom</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p data-start="158" data-end="277">Write a program that asks the user to enter a string.<br data-start="211" data-end="214" /> The program should check if the string is a <span data-start="260" data-end="274">palindrome</span>.</p>
<p data-start="284" data-end="389">A string is a palindrome if it is the same when read <span data-start="337" data-end="359">from left to right</span> and <span data-start="364" data-end="386">from right to left</span>.</p>
<p data-start="396" data-end="470">If the string is a palindrome, print <code data-start="433" data-end="439">true</code>.<br data-start="440" data-end="443" /> Otherwise, print <code data-start="462" data-end="469">false</code>.</p>
<p data-start="396" data-end="470"><strong data-start="472" data-end="507">Examples of palindrome strings:</strong><br data-start="507" data-end="510" /> <code data-start="510" data-end="519">RaceCar</code><br data-start="534" data-end="537" /> <code data-start="537" data-end="544">madam</code></p>]]></text>
